{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run emulator (roms/rom.bin)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/mdplayer.exe",
            "args": [],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "build",
            "MIMode": "gdb",
            "miDebuggerPath": "C:/mingw64/bin/gdb.exe",
            "externalConsole": false,
            "setupCommands": [
                {
                    "description": "Enable pretty-printing",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Headless check (300 frames + screenshot)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/mdplayer.exe",
            "args": ["--frames", "300", "--screenshot", "build/f300.png"],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "build",
            "MIMode": "gdb",
            "miDebuggerPath": "C:/mingw64/bin/gdb.exe",
            "externalConsole": false
        }
    ]
}
